{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Represents an electrical or plumbing product available in the catalog.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "longDescription": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "barcode": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "unit": { "type": "string" }
      },
      "required": ["name", "price", "category", "images"]
    },
    "UserSelfie": {
      "title": "UserSelfie",
      "description": "An image captured by a user for AI-powered visual search purposes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl", "createdAt"]
    }
  },
  "auth": {
    "providers": ["google", "facebook", "password", "anonymous"]
  },
  "firestore": {
    "/products/{productId}": {
      "schema": { "$ref": "#/backend/entities/Product" },
      "description": "Publicly readable collection of all shop products."
    },
    "/userSelfies/{selfieId}": {
      "schema": { "$ref": "#/backend/entities/UserSelfie" },
      "description": "Admin-viewable images uploaded via visual search."
    }
  }
}
