
rules_version = '2';

/**
 * Alpha Electricals & Plumbing Ltd - Security Rules
 * 
 * CORE PHILOSOPHY:
 * - Products: Publicly readable and writable for prototype seeding and management.
 * - User Selfies: Publicly writable (for uploads) and readable (for admin viewing).
 * - Reviews: Publicly readable and writable for customer feedback.
 * - Roles: Publicly accessible for prototype testing.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow full access to products for prototype seeding and dashboard management
    match /products/{productId} {
      allow read, list, write: if true;
    }

    // Allow users to upload selfies and admins to view them
    match /userSelfies/{selfieId} {
      allow create, read, list: if true;
    }

    // Allow public reviews for the prototype
    match /reviews/{reviewId} {
      allow read, list, create: if true;
    }

    // Allow roles management for prototype setup
    match /roles_admin/{userId} {
      allow read, write: if true;
    }
  }
}
