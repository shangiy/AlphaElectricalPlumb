rules_version = '2';

/**
 * Watkins Writer's Nook - Security Rules
 * 
 * CORE PHILOSOPHY:
 * This ruleset implements a dual-layered security model: strict path-based ownership 
 * for private user data (drafts, prompts) and administrative control for public-facing 
 * content (published blog posts, author profiles, tags). It leverages Database-Backed 
 * Access Control (DBAC) for global administrative roles.
 * 
 * DATA STRUCTURE:
 * - Public Data: /authorProfiles, /blogPosts, /tags are publicly readable.
 * - Private Data: /users/{userId}/draftBlogPosts and /users/{userId}/inspirationPrompts 
 *   are nested under the user's UID to enforce strict isolation.
 * - Administrative Roles: Handled via the /roles_admin/{userId} collection.
 * - Inbound Feedback: /contactSubmissions allows public writing but admin-only reading.
 * 
 * KEY SECURITY DECISIONS:
 * 1. DBAC for Admins: Administrative privileges are checked by verifying the existence 
 *    of a document in the /roles_admin collection.
 * 2. Authorization Independence: Critical fields like 'authorId' or 'id' are validated 
 *    against the path and the authenticated user's UID to ensure documents cannot be 
 *    "orphaned" or misattributed.
 * 3. Structural Segregation: Drafts and Published posts are separated into different 
 *    collections to ensure that public listing requests never accidentally leak drafts.
 * 4. Relational Integrity: On creation of user-owned documents, we strictly enforce 
 *    that the internal data matches the authenticated user.
 * 
 * DENORMALIZATION FOR AUTHORIZATION:
 * - The 'authorId' or 'authorUid' is stored directly on documents to avoid 
 *   expensive get() calls when verifying ownership.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the user owns the existing document and it exists. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for Author Profiles. Publicly readable, owner or admin writable.
     * @path /authorProfiles/{authorUid}
     * @allow (get) Any user. (update) User whose UID matches authorUid.
     * @deny (update) User attempting to edit another author's profile.
     * @principle Public Read with Owner-Only/Admin Writes.
     */
    match /authorProfiles/{authorUid} {
      allow get, list: if true;
      allow create: if (isOwner(authorUid) || isAdmin()) && request.resource.data.id == authorUid;
      allow update: if resource != null && (isOwner(authorUid) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if resource != null && (isOwner(authorUid) || isAdmin());
    }

    /**
     * @description Rules for Published Blog Posts. Publicly readable, admin-only writes.
     * @path /blogPosts/{blogPostId}
     * @allow (list) Any user. (create) Authenticated admin.
     * @deny (create) Non-admin authenticated user.
     * @principle Admin-controlled public content.
     */
    match /blogPosts/{blogPostId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if resource != null && isAdmin();
    }

    /**
     * @description Rules for Draft Blog Posts. Strictly private to the owner.
     * @path /users/{authorUid}/draftBlogPosts/{draftBlogPostId}
     * @allow (list) The user matching authorUid.
     * @deny (get) Any user other than the owner.
     * @principle Path-based ownership for private drafts.
     */
    match /users/{authorUid}/draftBlogPosts/{draftBlogPostId} {
      allow get, list: if isOwner(authorUid);
      allow create: if isOwner(authorUid) && request.resource.data.authorId == authorUid;
      allow update: if isExistingOwner(authorUid) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingOwner(authorUid);
    }

    /**
     * @description Rules for Blog Tags. Publicly readable, admin-only writes.
     * @path /tags/{tagId}
     * @allow (get) Any user. (create) Admin.
     * @deny (delete) Any non-admin.
     * @principle Global taxonomy managed by admins.
     */
    match /tags/{tagId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if resource != null && isAdmin();
    }

    /**
     * @description Rules for Contact Form Submissions. Public write, admin-only read.
     * @path /contactSubmissions/{submissionId}
     * @allow (create) Any user (even unauthenticated). (list) Admin.
     * @deny (get) The person who just submitted the form.
     * @principle Restricted feedback loop (Public Write / Admin Read).
     */
    match /contactSubmissions/{submissionId} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow update, delete: if resource != null && isAdmin();
    }

    /**
     * @description Rules for AI Inspiration Prompts. Strictly private to the owner.
     * @path /users/{authorUid}/inspirationPrompts/{promptId}
     * @allow (create) The user matching authorUid.
     * @deny (list) Another authenticated user.
     * @principle Path-based ownership for private creative assets.
     */
    match /users/{authorUid}/inspirationPrompts/{promptId} {
      allow get, list: if isOwner(authorUid);
      allow create: if isOwner(authorUid) && request.resource.data.authorId == authorUid;
      allow update: if isExistingOwner(authorUid) && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isExistingOwner(authorUid);
    }

    /**
     * @description Rules for Administrative Roles. Admin-only management.
     * @path /roles_admin/{userId}
     * @allow (get) User checking their own admin status. (list) Existing admins.
     * @deny (create) Non-admin users.
     * @principle Database-Backed Access Control (DBAC).
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

  }
}