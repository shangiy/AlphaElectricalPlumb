
rules_version = '2';

/**
 * Alpha Electricals & Plumbing Ltd - Security Rules
 * 
 * CORE PHILOSOPHY:
 * - Products: Publicly readable. Creation is allowed for seeding and testing.
 * - User Selfies: Publicly writable. Readable only by admins.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // For the prototype phase, we can use a metadata check or a specific collection
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /products/{productId} {
      allow read, list: if true;
      // Allow creation for seeding the prototype database
      allow create: if true;
      // Restrict updates and deletes to admins
      allow update, delete: if isAdmin();
    }

    match /userSelfies/{selfieId} {
      allow create: if true;
      allow read, list: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }
  }
}
